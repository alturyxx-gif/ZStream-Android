    <string name="tv_update_phone_flow">Actualización desde el teléfono</string>
    <string name="tv_update_phone_flow_description">Usa el teléfono para realizar la configuración. En ZStream para teléfono, abre el botón de TV de la barra de navegación superior y sigue los pasos de actualización.</string>
    <string name="tv_update_same_network">Mantén el teléfono y la TV en la misma red Wi-Fi. Si la TV usa Ethernet, no pasa nada siempre que esté en la misma red local.</string>
    <string name="tv_update_phone_instructions_title">Qué hacer en el teléfono</string>
    <string name="tv_update_phone_instructions">Abre ZStream en el teléfono, toca el botón de TV de la barra de navegación superior y sigue las instrucciones de actualización de la aplicación. Esta página solo enlaza a los ajustes de Android que puedes necesitar.</string>
    <string name="tv_update_wifi_settings">Ajustes de Wi-Fi</string>
    <string name="tv_update_about_build_number">Información / Número de compilación</string>
    <string name="tv_update_developer_adb_wireless">Opciones de desarrollador / Depuración ADB / Depuración inalámbrica</string>
    <string name="tv_update_developer_not_enabled">Las opciones de desarrollador no están activadas en esta TV.</string>
    <string name="tv_update_step_open_about">Paso 1 — Abre Información</string>
    <string name="tv_update_open_about_description">Ve a Ajustes → Preferencias del dispositivo → Información. Si tu TV lo muestra en otro lugar, los botones siguientes te llevarán a las páginas correctas.</string>
    <string name="tv_update_step_tap_build_number">Paso 2 — Toca 7 veces Número de compilación</string>
    <string name="tv_update_tap_build_number_description">Busca la opción Número de compilación y tócala 7 veces. Verás un mensaje que confirma que las opciones de desarrollador ya están activadas.</string>
    <string name="tv_update_step_come_back">Paso 3 — Vuelve aquí</string>
    <string name="tv_update_return_description">Pulsa Atrás o vuelve a ZStream. Esta pantalla detectará el cambio automáticamente.</string>
    <string name="tv_update_developer_enabled">Las opciones de desarrollador están activadas. Activa la depuración ADB y vuelve aquí.</string>
    <string name="tv_update_step_open_settings">Paso 1 — Abre la página de ajustes correcta</string>
    <string name="tv_update_open_settings_description">Abre Opciones de desarrollador en la TV y activa la depuración ADB. Los botones siguientes te llevarán allí directamente.</string>
    <string name="tv_update_step_enable_wireless">Paso 2 — Activa la depuración inalámbrica</string>
    <string name="tv_update_enable_wireless_description">Activa la depuración USB, busca Depuración inalámbrica y actívala también. Ambas son necesarias para enviar el APK por Wi-Fi.</string>
    <string name="tv_update_return_adb_description">Pulsa Atrás o vuelve a ZStream. Cuando ADB esté activo, esta pantalla lo confirmará y desbloqueará la página de versiones.</string>
    <string name="tv_update_adb_enabled">La depuración ADB está activa. Lo has hecho bien.</string>
    <string name="tv_update_next_step">Paso siguiente</string>
    <string name="tv_update_next_step_description">Ya puedes ir a la página de versiones disponibles. Allí podrás elegir el APK e instalar la actualización en segundo plano.</string>
