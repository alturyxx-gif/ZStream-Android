    <string name="transport_intro_title">Let\'s get your TV set up</string>
    <string name="transport_intro_description">We\'ll walk you through pairing and installing the app on your TV — it only takes a minute.</string>
    <string name="transport_same_wifi_hint">Keep the phone and TV on the same Wi-Fi (skip guest networks and VPNs), and leave ZStream open on the TV while you pair.</string>
    <string name="transport_get_started">Get started</string>
    <string name="transport_automatic_pairing">Automatic wireless pairing</string>
    <string name="transport_auto_step_1_title">Step 1 — Turn on Developer options</string>
    <string name="transport_auto_step_1_body">On the TV: Settings → Device Preferences → About → Android TV OS build. Tap it repeatedly until Developer options unlock.</string>
    <string name="transport_auto_step_2_title">Step 2 — Enable Wireless debugging</string>
    <string name="transport_auto_step_2_body">Back in Device Preferences, open Developer options, then turn on USB debugging and Wireless debugging.</string>
    <string name="transport_auto_step_3_title">Step 3 — Enter the pairing code</string>
    <string name="transport_auto_step_3_body">Tap "Pair device with pairing code" and leave that screen open. Enter the 6-digit code below — ZStream finds the TV automatically.</string>
    <string name="transport_pairing_code_6_digit">6-digit pairing code</string>
    <string name="transport_find_and_pair_tv">Find and pair TV</string>
    <string name="transport_finding_and_pairing">Finding and pairing with TV…</string>
