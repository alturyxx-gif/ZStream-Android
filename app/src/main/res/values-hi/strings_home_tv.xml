    <string name="transport_automatic_pairing">स्वचालित वायरलेस पेयरिंग</string>
    <string name="transport_auto_step_1_title">चरण 1 — डेवलपर विकल्प चालू करें</string>
    <string name="transport_auto_step_1_body">टीवी पर: सेटिंग → डिवाइस प्राथमिकताएँ → परिचय → Android TV OS बिल्ड। डेवलपर विकल्प चालू होने तक इसे बार-बार टैप करें।</string>
    <string name="transport_auto_step_2_title">चरण 2 — वायरलेस डीबगिंग चालू करें</string>
    <string name="transport_auto_step_2_body">डिवाइस प्राथमिकताओं में वापस जाकर डेवलपर विकल्प खोलें, फिर USB डीबगिंग और वायरलेस डीबगिंग चालू करें।</string>
    <string name="transport_auto_step_3_title">चरण 3 - युग्मन कोड दर्ज करें</string>
    <string name="transport_auto_step_3_body">"पेयरिंग कोड के साथ डिवाइस को पेयर करें" पर टैप करें और उस स्क्रीन को खुला छोड़ दें। नीचे 6-अंकीय कोड दर्ज करें -ZStream स्वचालित रूप से टीवी ढूंढता है।</string>
    <string name="transport_pairing_code_6_digit">6-अंकीय युग्मन कोड</string>
