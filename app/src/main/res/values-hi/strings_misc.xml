    <string name="tv_update_phone_flow">फ़ोन अद्यतन प्रवाह</string>
    <string name="tv_update_phone_flow_description">वास्तविक सेटअप करने के लिए फ़ोन का उपयोग करें. अपने फ़ोन पर ZStream में, शीर्ष नेविगेशन बार में टीवी बटन खोलें और वहां अपडेट चरणों का पालन करें।</string>
    <string name="tv_update_same_network">फोन और टीवी को एक ही Wi-Fi पर रखें। यदि टीवी ईथरनेट पर है, तो यह तब तक ठीक है जब तक वह उसी स्थानीय नेटवर्क पर है।</string>
    <string name="tv_update_phone_instructions_title">फ़ोन पर क्या करें</string>
    <string name="tv_update_phone_instructions">फ़ोन पर ZStream खोलें, शीर्ष नेविगेशन बार में टीवी बटन पर टैप करें और इन-ऐप अपडेट निर्देशों का पालन करें। यह पृष्ठ केवल उन Android सेटिंग्स से लिंक है जिनकी आपको आवश्यकता हो सकती है।</string>
    <string name="tv_update_wifi_settings">Wi-Fi सेटिंग्स</string>
    <string name="tv_update_about_build_number">परिचय / बिल्ड नंबर</string>
    <string name="tv_update_developer_adb_wireless">डेवलपर विकल्प / ADB डीबगिंग / वायरलेस डीबगिंग</string>
    <string name="tv_update_developer_not_enabled">इस टीवी पर डेवलपर विकल्प चालू नहीं हैं।</string>
    <string name="tv_update_step_open_about">चरण 1 - अबाउट खोलें</string>
    <string name="tv_update_open_about_description">सेटिंग्स → डिवाइस प्राथमिकताएं → अबाउट पर जाएं। यदि आपका टीवी इसे कहीं और छिपाता है, तो नीचे दिए गए बटन सही स्थानों पर पहुंच जाते हैं।</string>
    <string name="tv_update_step_tap_build_number">चरण 2 - बिल्ड नंबर पर 7 बार टैप करें</string>
    <string name="tv_update_tap_build_number_description">बिल्ड नंबर प्रविष्टि ढूंढें और इसे 7 बार टैप करें। आपको एक संदेश दिखाई देगा जो पुष्टि करेगा कि डेवलपर विकल्प अब सक्षम हैं।</string>
    <string name="tv_update_step_come_back">चरण 3 - यहाँ वापस आएँ</string>
    <string name="tv_update_return_description">वापस दबाएँ या ZStream पर वापस लौटें। यह स्क्रीन स्वचालित रूप से परिवर्तन का पता लगा लेती है.</string>
    <string name="tv_update_developer_enabled">डेवलपर विकल्प चालू हैं। ADB डीबगिंग चालू करें, फिर यहाँ वापस आएँ।</string>
    <string name="tv_update_step_open_settings">चरण 1 - सही सेटिंग पृष्ठ खोलें</string>
    <string name="tv_update_open_settings_description">टीवी पर डेवलपर विकल्प खोलें और ADB डिबगिंग पर स्विच करें। नीचे दिए गए बटन सीधे वहां कूदते हैं।</string>
    <string name="tv_update_step_enable_wireless">चरण 2 - वायरलेस डिबगिंग सक्षम करें</string>
    <string name="tv_update_enable_wireless_description">USB डिबगिंग चालू करें, फिर वायरलेस डिबगिंग ढूंढें और इसे भी सक्षम करें। APK को Wi-Fi पर धकेलने के लिए दोनों की आवश्यकता है।</string>
    <string name="tv_update_return_adb_description">वापस दबाएँ या ZStream पर वापस लौटें। जब ADB चालू होगा, तो यह स्क्रीन इसकी पुष्टि करेगी और रिलीज़ पेज को अनलॉक करेगी।</string>
    <string name="tv_update_adb_enabled">ADB डिबगिंग चालू है। आपने सही काम किया।</string>
    <string name="tv_update_next_step">अगला कदम</string>
    <string name="tv_update_next_step_description">अब आप उपलब्ध रिलीज़ पेज पर जारी रख सकते हैं। वहां आप APK चुन सकते हैं और बैकग्राउंड में अपडेट इंस्टॉल कर सकते हैं।</string>
