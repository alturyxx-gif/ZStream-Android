    <string name="tv_update_phone_flow">Mise à jour depuis le téléphone</string>
    <string name="tv_update_phone_flow_description">Utilisez le téléphone pour effectuer la configuration. Dans ZStream sur votre téléphone, ouvrez le bouton TV de la barre de navigation supérieure et suivez les étapes de mise à jour.</string>
    <string name="tv_update_same_network">Gardez le téléphone et la TV sur le même réseau Wi-Fi. La TV peut utiliser Ethernet tant qu’elle se trouve sur le même réseau local.</string>
    <string name="tv_update_phone_instructions_title">Procédure sur le téléphone</string>
    <string name="tv_update_phone_instructions">Ouvrez ZStream sur le téléphone, appuyez sur le bouton TV dans la barre de navigation supérieure et suivez les instructions de mise à jour dans l’application. Cette page renvoie uniquement vers les paramètres Android dont vous pourriez avoir besoin.</string>
    <string name="tv_update_wifi_settings">Paramètres Wi-Fi</string>
    <string name="tv_update_about_build_number">À propos / Numéro de build</string>
    <string name="tv_update_developer_adb_wireless">Options pour les développeurs / Débogage ADB / Débogage sans fil</string>
    <string name="tv_update_developer_not_enabled">Les options pour les développeurs ne sont pas activées sur cette TV.</string>
    <string name="tv_update_step_open_about">Étape 1 — Ouvrir À propos</string>
    <string name="tv_update_open_about_description">Accédez à Paramètres → Préférences relatives à l’appareil → À propos. Si votre TV le place ailleurs, les boutons ci-dessous ouvrent les pages appropriées.</string>
    <string name="tv_update_step_tap_build_number">Étape 2 — Appuyer 7 fois sur Numéro de build</string>
    <string name="tv_update_tap_build_number_description">Trouvez l’option Numéro de build et appuyez dessus 7 fois. Un message confirmera que les options pour les développeurs sont activées.</string>
    <string name="tv_update_step_come_back">Étape 3 — Revenir ici</string>
    <string name="tv_update_return_description">Appuyez sur Retour ou revenez dans ZStream. Cet écran détectera automatiquement la modification.</string>
    <string name="tv_update_developer_enabled">Les options pour les développeurs sont activées. Activez le débogage ADB, puis revenez ici.</string>
    <string name="tv_update_step_open_settings">Étape 1 — Ouvrir la bonne page de paramètres</string>
    <string name="tv_update_open_settings_description">Ouvrez les options pour les développeurs sur la TV et activez le débogage ADB. Les boutons ci-dessous vous y conduisent directement.</string>
    <string name="tv_update_step_enable_wireless">Étape 2 — Activer le débogage sans fil</string>
    <string name="tv_update_enable_wireless_description">Activez le débogage USB, puis recherchez et activez également le débogage sans fil. Les deux sont nécessaires pour envoyer l’APK par Wi-Fi.</string>
    <string name="tv_update_return_adb_description">Appuyez sur Retour ou revenez dans ZStream. Lorsque l’ADB est activé, cet écran le confirmera et déverrouillera la page des versions.</string>
    <string name="tv_update_adb_enabled">Le débogage ADB est activé. Tout est prêt.</string>
    <string name="tv_update_next_step">Étape suivante</string>
    <string name="tv_update_next_step_description">Vous pouvez maintenant ouvrir la page des versions disponibles. Vous pourrez y choisir l’APK et installer la mise à jour en arrière-plan.</string>
