    <string name="tv_update_about_build_number">Tentang / Nomor build</string>
    <string name="tv_update_developer_adb_wireless">Opsi pengembang / Debug ADB / Debug nirkabel</string>
    <string name="tv_update_developer_not_enabled">Opsi pengembang belum diaktifkan di TV ini.</string>
    <string name="tv_update_step_open_about">Langkah 1 — Buka Tentang</string>
    <string name="tv_update_open_about_description">Buka Pengaturan → Preferensi Perangkat → Tentang. Jika TV menaruhnya di tempat lain, tombol di bawah akan membuka lokasi yang tepat.</string>
    <string name="tv_update_step_tap_build_number">Langkah 2 — Ketuk Nomor Build 7 kali</string>
    <string name="tv_update_tap_build_number_description">Temukan entri Nomor Build lalu ketuk 7 kali. Pesan akan muncul untuk mengonfirmasi bahwa Opsi Pengembang telah aktif.</string>
    <string name="tv_update_step_come_back">Langkah 3 — Kembali ke sini</string>
    <string name="tv_update_return_description">Tekan Kembali atau buka lagi ZStream. Layar ini mendeteksi perubahan secara otomatis.</string>
    <string name="tv_update_developer_enabled">Opsi pengembang sudah aktif. Aktifkan debug ADB, lalu kembali ke sini.</string>
    <string name="tv_update_step_open_settings">Langkah 1 — Buka halaman pengaturan yang tepat</string>
    <string name="tv_update_open_settings_description">Buka Opsi Pengembang di TV dan aktifkan debug ADB. Tombol di bawah akan membukanya langsung.</string>
    <string name="tv_update_step_enable_wireless">Langkah 2 — Aktifkan Debug Nirkabel</string>
    <string name="tv_update_enable_wireless_description">Aktifkan Debug USB, lalu temukan dan aktifkan Debug Nirkabel. Keduanya diperlukan untuk mengirim APK melalui Wi-Fi.</string>
    <string name="tv_update_return_adb_description">Tekan Kembali atau buka lagi ZStream. Saat ADB aktif, layar ini akan mengonfirmasi dan membuka halaman rilis.</string>
    <string name="tv_update_adb_enabled">Debug ADB sudah aktif. Langkah Anda benar.</string>
    <string name="tv_update_next_step">Langkah berikutnya</string>
    <string name="tv_update_next_step_description">Sekarang Anda dapat membuka halaman rilis yang tersedia. Di sana Anda dapat memilih APK dan memasang pembaruan di latar belakang.</string>
